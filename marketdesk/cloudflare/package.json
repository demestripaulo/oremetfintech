{
  "name": "marketdesk-cloudflare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-assets": "node -e \"require('fs').cpSync('../frontend','public',{recursive:true})\"",
    "dev": "npm run sync-assets && wrangler dev",
    "deploy": "npm run sync-assets && wrangler deploy",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^4.20.0"
  }
}
